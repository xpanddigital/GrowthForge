{
  "crons": [
    {
      "path": "/api/cron/discovery",
      "schedule": "0 6 * * 2,5"
    },
    {
      "path": "/api/cron/monitor",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/entity",
      "schedule": "0 8 * * 3"
    },
    {
      "path": "/api/cron/reviews",
      "schedule": "0 9 * * 4"
    },
    {
      "path": "/api/cron/press-coverage",
      "schedule": "0 10 * * 5"
    }
  ],
  "headers": [
    {
      "source": "/research/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=600, must-revalidate"
        }
      ]
    },
    {
      "source": "/research",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=600, must-revalidate"
        }
      ]
    }
  ]
}
