# Payments — Stripe
# Create products at https://dashboard.stripe.com/products
# Then copy the price IDs from each product's pricing section
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Stripe Price IDs — create 4 monthly recurring products in Stripe Dashboard:
# 1. "MentionLayer Solo" → $97/month
# 2. "MentionLayer Growth" → $297/month
# 3. "MentionLayer Agency" → $397/month
# 4. "MentionLayer Agency Pro" → $997/month
# Copy the price_xxx ID from each and paste below (both server + client versions)
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_AGENCY_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_SOLO=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY=price_...
NEXT_PUBLIC_STRIPE_PRICE_AGENCY_PRO=price_...

# Stripe Webhook — create at https://dashboard.stripe.com/webhooks
# Endpoint URL: https://mentionlayer.com/api/webhooks/stripe
# Events: checkout.session.completed, invoice.payment_succeeded,
#          customer.subscription.deleted, customer.subscription.updated

# Cron Security
CRON_SECRET=...

# Email sender identity
AUDIT_FROM_EMAIL=joel@mentionlayer.com
AUDIT_FROM_NAME=Joel House
BOOKING_URL=https://calendly.com/joelhouse/ai-visibility

# App
NEXT_PUBLIC_APP_URL=https://mentionlayer.com
